# LLM Configuration
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-reasoner

# Port Configuration
FRONTEND_PORT=3000
BACKEND_PORT=8000
REDIS_PORT=6379
